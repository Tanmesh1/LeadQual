APP_NAME="Lead Qualification Platform"
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=json

API_V1_PREFIX=/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=lead_qualification
POSTGRES_USER=lead_user
POSTGRES_PASSWORD=lead_password

DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

INDIAMART_MOBILE_NUMBER=7718885169
INDIAMART_HEADLESS=false
INDIAMART_SLOW_MO_MS=0
INDIAMART_TIMEOUT_MS=30000
INDIAMART_MANUAL_LOGIN_TIMEOUT_SECONDS=120
INDIAMART_LEAD_LIST_WAIT_SECONDS=20
INDIAMART_MAX_PAGES=10
INDIAMART_BATCH_SIZE=25
INDIAMART_OPEN_LEAD_DETAILS=false
INDIAMART_API_BASE_URL=http://localhost:8000/api/v1
INDIAMART_SESSION_STATE_PATH=.runtime/indiamart/storage_state.json
INDIAMART_DIAGNOSTICS_PATH=.runtime/indiamart/diagnostics
INDIAMART_SELECTORS_PATH=src/app/automation/indiamart/selectors/buy_leads.json
INDIAMART_RETRY_ATTEMPTS=3
INDIAMART_RETRY_BACKOFF_SECONDS=1

REPORT_OUTPUT_PATH=Lead_Intelligence_Report.xlsx

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=reports@example.com
SMTP_USE_TLS=true
REPORT_EMAIL_RECIPIENTS=owner@example.com,sales@example.com

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_IDS=

REPORT_DELIVERY_RETRY_ATTEMPTS=3
REPORT_DELIVERY_RETRY_BACKOFF_SECONDS=2
REPORT_SCHEDULER_ENABLED=false
REPORT_SCHEDULER_TIMEZONE=Asia/Kolkata
DAILY_REPORT_TIME=09:00
WEEKLY_REPORT_DAY=mon
MONTHLY_REPORT_DAY=1
